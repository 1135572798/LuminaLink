{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src/main/**/*.ts", "src/cli/**/*.ts", "src/core/**/*.ts", "src/shared/**/*.ts"]
}
