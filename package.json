{
  "name": "luminalink",
  "version": "0.1.0",
  "description": "Chinese-first desktop manager for local AI skills, plugins, Agent files, and translated documentation.",
  "private": false,
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "pnpm build:main && concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && electron .\"",
    "build": "vue-tsc --noEmit && vite build && pnpm build:main",
    "build:main": "tsc -p tsconfig.node.json",
    "preview": "vite preview --host 127.0.0.1",
    "luminalink": "tsx src/cli/index.ts",
    "scan": "tsx src/cli/index.ts scan",
    "doctor": "tsx src/cli/index.ts doctor"
  },
  "keywords": [
    "electron",
    "ai-tools",
    "codex",
    "skills",
    "plugins",
    "translation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "lucide-vue-next": "^0.468.0",
    "markdown-it": "^14.1.0",
    "sql.js": "^1.12.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "@types/sql.js": "^1.4.11",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10",
    "wait-on": "^8.0.1"
  }
}
